# Copy to .env and adjust. Render: set these in the dashboard.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/enrollment_db
SECRET_KEY=replace-with-long-random-string
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# Leave false/unset: app runs create_all + PostgreSQL patches on startup.
SKIP_AUTO_DB_SETUP=false
# Hosted Postgres: optional override (disable | allow | prefer | require | verify-full).
# DATABASE_SSL_MODE=prefer
# Startup retries if DB is slow to accept connections (Render cold start).
# DB_STARTUP_ATTEMPTS=10
# DB_STARTUP_DELAY_SEC=2.5
# If true, deploy fails when DB is unreachable / wrong password (default: false = degraded mode).
# STRICT_DB_STARTUP=false
# Optional: OpenAI key for smarter chatbot (otherwise rule-based replies)
OPENAI_API_KEY=
